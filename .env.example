# At least one of the following API keys is required
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...

# Server config
PORT=3000
HOST=127.0.0.1
DB_PATH=~/.velanza/data.db

# Optional: override default models
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6
OPENAI_DEFAULT_MODEL=gpt-4o
GOOGLE_DEFAULT_MODEL=gemini-2.5-flash

# Logging
LOG_LEVEL=info
# error | warn | info | debug

# Optional: concurrent LLM call limit (default 5)
# LLM_CONCURRENCY_LIMIT=5

# Optional: LLM call timeout in ms (default 60000)
# LLM_TIMEOUT_MS=60000

# Set to 1 to run E2E tests against real providers (costs money)
# RUN_E2E_TESTS=0
